generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  name             String?
  role             String           @default("USER")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  listings         Listing[]
  repairerProfile  RepairerProfile?
  /// Repair attempts this user leads as a repairer account.
  repairStoriesAsRepairer RepairStory[]        @relation("RepairStoryRepairer")
  listingMessagesSent     ListingMessage[]     @relation("ListingMessageSender")
  repairStoryMessagesSent RepairStoryMessage[] @relation("RepairStoryMessageSender")
}

/// Public repair service page: bio, expertise, service copy, and job/rating aggregates.
model RepairerProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                 String   @unique
  bio                  String   @default("")
  serviceDescription   String   @default("")
  /// JSON array of strings, e.g. ["Electronics","Bicycles"]
  expertise            String   @default("[]")
  completedJobsCount   Int      @default(0)
  /// Sum of star ratings (1–5) from completed jobs; average = ratingSum / ratingCount
  ratingSum            Int      @default(0)
  ratingCount          Int      @default(0)
  /// Public HTTPS URL for a workshop or profile photo (paste link; uploads can be added later).
  servicePhotoUrl      String?
  /// Human-readable service area label shown next to the map.
  serviceLocationLabel String   @default("")
  /// WGS84 coordinates for the embedded map (both should be set for a pin).
  serviceLatitude      Float?
  serviceLongitude     Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  completedJobs RepairerCompletedJob[]
}

/// A finished repair engagement shown on the public repairer page (expandable details).
model RepairerCompletedJob {
  id                  String          @id @default(uuid())
  repairerProfileId   String
  repairerProfile     RepairerProfile @relation(fields: [repairerProfileId], references: [id], onDelete: Cascade)
  title               String
  itemSummary         String          @default("")
  completedAt         DateTime        @default(now())
  /// 1–5 when the customer rated; omit when not rated.
  ratingStars         Int?
  agreementSummary    String          @default("")
  messagesSummary     String          @default("")
  /// Filled when the repair-story feature ships; empty shows a placeholder in the UI.
  repairStoryNotes    String          @default("")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([repairerProfileId, completedAt])
}

/// A broken-item case (public listing). Use `id` as the stable case / item id in product copy.
model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String?
  status      String   @default("OPEN")
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// All repair attempts / stories tied to this case (multiple repairers or re-tries after a branch).
  repairStories   RepairStory[]
  /// Item-level thread: owner + any repairer who has a story on this listing.
  listingMessages ListingMessage[]
}

/// One repairer’s attempt on one listing. Several rows can exist per listing (different repairers or branched retries).
/// Status values are app-level strings — see `src/lib/repairStoryStatus.ts` (we expect to adjust while the product evolves).
model RepairStory {
  id               String   @id @default(uuid())
  listingId        String
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  repairerUserId   String
  repairer         User     @relation("RepairStoryRepairer", fields: [repairerUserId], references: [id], onDelete: Cascade)
  status           String   @default("APPLIED")
  /// Optional link when this story continues after a previous attempt ended (e.g. cannot fix → new line of work).
  branchedFromId   String?
  branchedFrom     RepairStory?  @relation("StoryBranch", fields: [branchedFromId], references: [id], onDelete: SetNull)
  branchChildren   RepairStory[] @relation("StoryBranch")
  /// Agreed service price in minor units (e.g. cents); set when scope is agreed — payment integration comes later.
  agreedPriceCents Int?
  /// Stub for escrow: NONE → HELD → RELEASED or REFUNDED until a payments provider exists.
  escrowState      String   @default("NONE")
  agreedAt         DateTime?
  jobCompletedAt   DateTime?
  paidAt           DateTime?
  closedReason     String?
  /// Customer (listing owner) rates the repairer 1–5 when work finishes.
  customerScore    Int?
  /// Repairer rates the customer 1–5 when work finishes.
  repairerScore    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages RepairStoryMessage[]

  @@index([listingId, status])
  @@index([repairerUserId, status])
}

/// Messages visible to listing owner and every repairer who has a story on this listing.
model ListingMessage {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("ListingMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
}

/// Per–repair-story discussion (agreement, troubleshooting, handover) between owner and that repairer only.
model RepairStoryMessage {
  id            String      @id @default(uuid())
  repairStoryId String
  repairStory   RepairStory @relation(fields: [repairStoryId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation("RepairStoryMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body          String
  createdAt     DateTime    @default(now())

  @@index([repairStoryId, createdAt])
}
