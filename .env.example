# PostgreSQL connection string
# Local dev (Docker): postgresql://postgres:dev@localhost:5432/fiks
# Vercel Postgres: auto-set when you add the Vercel Postgres integration.
# In Vercel → Settings → Environment Variables, ensure DATABASE_URL applies to
# Production and Preview (not "Development only"), so `next build` can connect.
DATABASE_URL="postgresql://postgres:dev@localhost:5432/fiks"

# JWT session signing key (min 32 characters). Generate a random one for production.
AUTH_SECRET="fiks-dev-jwt-secret-key-min-32-chars!!"

# Vercel Blob storage token (auto-set on Vercel; needed locally only if testing blob uploads)
BLOB_READ_WRITE_TOKEN=""
